{
    "name": "neural-web",
    "version": "0.1.0",
    "description": "NeuralWeb - AI-Powered Browser built with Electron",
    "main": "dist/electron/main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
        "dev:vite": "vite",
        "dev:electron": "tsc -p electron/tsconfig.json && NODE_ENV=development electron .",
        "build": "vite build && tsc -p electron/tsconfig.json",
        "build:all": "npm run build && electron-builder",
        "preview": "vite preview",
        "lint": "eslint . --max-warnings=0",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "vitest run",
        "test:e2e": "npm run build && playwright test"
    },
    "keywords": [
        "browser",
        "ai",
        "electron",
        "chromium"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "electron-ollama": "^0.1.25",
        "lucide-react": "^0.555.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^10.1.0",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@types/uuid": "^9.0.7",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.4.0",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.3.6",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.58.0",
        "vite": "^5.0.8",
        "vitest": "^3.2.4"
    },
    "build": {
        "appId": "com.neuralweb.browser",
        "productName": "NeuralWeb",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "extendInfo": {
                "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect to devices."
            }
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}
